{
  "name": "cloudsync-cli",
  "version": "1.0.3",
  "description": "An open-source, Git-like version control CLI for secure cloud-to-local synchronization via encrypted SSH tunnels",
  "type": "module",
  "main": "./bin/cloudsync.js",
  "bin": {
    "cloudsync": "./bin/cloudsync.js"
  },
  "scripts": {
    "start": "node bin/cloudsync.js",
    "dev": "node --watch bin/cloudsync.js",
    "test": "node test.js",
    "lint": "eslint src/ || true",
    "lint:fix": "eslint src/ --fix || true",
    "format": "prettier --write \"**/*.js\" || true",
    "format:check": "prettier --check \"**/*.js\" || true",
    "build": "echo 'Build complete - CLI is ready to use'",
    "pkg:linux": "pkg bin/cloudsync.js -t node18-linux-x64 -o dist/cloudsync-linux",
    "pkg:macos": "pkg bin/cloudsync.js -t node18-macos-x64 -o dist/cloudsync-macos",
    "pkg:win": "pkg bin/cloudsync.js -t node18-win-x64 -o dist/cloudsync-win.exe",
    "pkg:all": "npm run pkg:linux && npm run pkg:macos && npm run pkg:win",
    "postinstall": "echo 'CloudSync-CLI installed successfully!'"
  },
  "keywords": [
    "cli",
    "sync",
    "ssh",
    "sftp",
    "rsync",
    "cloud",
    "replit",
    "version-control",
    "git",
    "file-transfer",
    "encryption",
    "devops",
    "deployment",
    "configuration",
    "environment",
    "dotenv",
    "secure",
    "cloud-sync",
    "synchronization"
  ],
  "author": {
    "name": "CloudSync Team",
    "email": "team@cloudsync.dev",
    "url": "https://github.com/Tech4File"
  },
  "contributors": [
    {
      "name": "CloudSync Contributors",
      "url": "https://github.com/Tech4File/cloudsync-cli/graphs/contributors"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tech4File/cloudsync-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Tech4File/cloudsync-cli/issues"
  },
  "homepage": "https://github.com/Tech4File/cloudsync-cli#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Tech4File"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "decompress": "^4.2.1",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.3.1",
    "figlet": "^1.7.0",
    "ini": "^4.1.1",
    "js-yaml": "^4.1.0",
    "lz4js": "^0.2.0",
    "open": "^9.1.0",
    "ora": "^7.0.1",
    "ssh2": "^1.15.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "brotli": "^1.1.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "x86",
    "arm64"
  ]
}
